# 远程部署环境变量 —— 复制为 deploy/.env 并填真实值。切勿提交 deploy/.env。
# docker compose -f deploy/docker-compose.remote.yml --env-file deploy/.env up -d --build

# ── 图库 Neo4j ──
# ⚠️ 必填强密码(不要用本地默认 localdev_change_me)。只在 compose 内网 + 回环用,
#    但仍要强密码以防本机其它进程/容器越权。
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── 对话 LLM(dasuapi,已验证支持约束解码)──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dasuapi.com/v1
OPENAI_MODEL=gpt-5.4

# ── 嵌入(智谱 embedding-3,2048 维)──
# ⚠️ EMBEDDER_DIM 首次写入即固化进 Neo4j schema,之后换模型需重建库。
EMBEDDER_API_KEY=
EMBEDDER_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDER_MODEL=embedding-3
EMBEDDER_DIM=2048

# ── 分区 / 并发 ──
GRAPHITI_GROUP_ID=draft
SEMAPHORE_LIMIT=6

# ── MCP HTTP 绑定(容器内)──
# 容器内必须绑 0.0.0.0 才能被宿主端口映射转发; 对外仍只经 nginx + Bearer 鉴权。
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# ── 反代鉴权用的 Bearer token(nginx vhost 校验;不被 server/compose 读)──
# 生成: openssl rand -hex 32   —— 填进这里 + 客户端 MCP 配置的 Authorization 头。
# 放这里只为集中管理;实际由 nginx map 或 conf 引用,见 deploy/nginx.kg.conf 注释。
KG_BEARER_TOKEN=
