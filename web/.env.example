# Copy to .env and fill in real values. Never commit .env.
#
# Neo4j connection for the web app's server functions (read-only Cypher).
# ⚠️ NO VITE_ prefix on purpose → these stay server-only, never inlined into the
#    client bundle. Never reference process.env.NEO4J_* from a .tsx component body.

# Local dev: the kg-neo4j docker-compose container (bolt on :7687).
# Deploy: point at 127.0.0.1:7687 (or the compose-internal bolt://neo4j:7687)
#         so Neo4j is never exposed to the public internet.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j

# Must match the root .env / docker-compose.yml (NEO4J_AUTH fallback).
NEO4J_PASSWORD=localdev_change_me

NEO4J_DATABASE=neo4j
