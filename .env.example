# OpenAI API key — used by Graphiti for entity/relation extraction.
# Copy this file to `.env` and fill in your real key. NEVER commit `.env`.
OPENAI_API_KEY=sk-...

# Optional: override the OpenAI model used for extraction.
# OPENAI_MODEL=gpt-4o-mini

# Local Kùzu database path (defaults to ./data/graphiti.kuzu if unset).
# KUZU_DB_PATH=./data/graphiti.kuzu
